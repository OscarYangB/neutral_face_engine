{
    "version": "0.1.0",
    "configurations": [
        {
            "name": "Debug neonatal engine",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/neonatal_engine.exe",
            "args": ["-q"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Import pretty-printing for gdb",
					"text": "python import sys;sys.path.insert(0, 'C:\\pretty_printer');from printers import register_libcxx_printer_loader;register_libcxx_printer_loader()",
					"ignoreFailures": false
				},
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": false
				},
				{
					"text": "set breakpoint pending on",
					"description": "Ensures that a breakpoint for abort will be set!",
					"ignoreFailures": true
				},
				{
					"text": "break abort",
					"description": "Breaks on failed asserts",
					"ignoreFailures": true
				},
				{
					"text": "set breakpoint pending auto",
					"description": "Setting back to default behaviour",
					"ignoreFailures": true
				}
			]
        }
    ]
}
